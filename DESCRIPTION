Package: MetaStat
Title: A Shiny Application for Meta-Analysis
Version: 1.0.0
Authors@R:
    c(person("Franco", "Suarez",
             email = "suarezfranco@agro.unc.edu.ar",
             role = c("aut", "cre"),
             comment = c(ORCID = "0000-0003-3179-2701")),
